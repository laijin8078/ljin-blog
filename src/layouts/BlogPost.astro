---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import TagList from '../components/TagList.astro';
import type { DateDisplayPrecision } from '../utils/frontmatterDates';

type Props = CollectionEntry<'blog'>['data'] & {
	slug?: string;
	pubDatePrecision?: DateDisplayPrecision;
	updatedDatePrecision?: DateDisplayPrecision;
};

const {
	title,
	description,
	pubDate,
	updatedDate,
	heroImage,
	tags,
	slug,
	pubDatePrecision = 'datetime',
	updatedDatePrecision = 'datetime',
} = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			main {
				width: 100%;
				max-width: none;
				margin: 0;
				padding: clamp(1.25rem, 4vw, 3rem) 0;
			}
			.hero-image {
				width: 100%;
			}
			.hero-image img {
				display: block;
				margin: 0 auto;
				border-radius: 12px;
				box-shadow: var(--box-shadow);
			}
			.prose {
				width: min(100%, 720px);
				max-width: none;
				margin: auto;
				padding: clamp(1rem, 3vw, 1.5rem);
				color: rgb(var(--gray-dark));
			}
			.title {
				margin-bottom: clamp(0.75rem, 2vw, 1rem);
				padding: clamp(0.5rem, 2vw, 1rem) 0;
				text-align: center;
			}
			.title h1 {
				margin: 0 0 0.5em 0;
				font-size: clamp(2rem, calc(1.25rem + 3.2vw), 3.052rem);
				line-height: 1.2;
				text-wrap: balance;
				overflow-wrap: anywhere;
			}
			.date {
				margin-bottom: 0.5em;
				color: rgb(var(--gray));
				font-size: clamp(0.9rem, calc(0.85rem + 0.2vw), 1rem);
				line-height: 1.5;
			}
			.views {
				margin-top: 0.4em;
				color: rgb(var(--gray));
				font-size: 0.85em;
			}
			.last-updated-on {
				font-style: italic;
			}
			@media (max-width: 720px) {
				main {
					padding-top: 1rem;
				}
				.title {
					margin-bottom: 0.5rem;
				}
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="hero-image">
					{heroImage && <Image width={1020} height={510} src={heroImage} alt="" />}
				</div>
				<div class="prose">
					<div class="title">
						<h1>{title}</h1>
						<div class="date">
							<FormattedDate date={pubDate} precision={pubDatePrecision} />
							{
								updatedDate && (
									<div class="last-updated-on">
										Last updated on <FormattedDate date={updatedDate} precision={updatedDatePrecision} />
									</div>
								)
							}
						</div>
						<TagList {tags} />
						{slug && <div class="views" data-view-counter data-slug={slug} hidden></div>}
						<hr />
					</div>
					<slot />
				</div>
			</article>
		</main>
		<Footer />
		<script>
			const counter = document.querySelector('[data-view-counter]');
			if (counter instanceof HTMLElement && counter.dataset.slug) {
				const slug = encodeURIComponent(counter.dataset.slug);
				fetch(`/api/views?slug=${slug}`, { method: 'POST' })
					.then((response) => (response.ok ? response.json() : null))
					.then((data) => {
						if (data && typeof data.views === 'number') {
							counter.textContent = `浏览 ${data.views} 次`;
							counter.hidden = false;
						}
					})
					.catch(() => {});
			}
		</script>
	</body>
</html>
