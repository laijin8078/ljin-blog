---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<h2 class="site-title">
			<a href="/">{SITE_TITLE}</a>
		</h2>
		<div class="internal-links">
			<HeaderLink href="/">首页</HeaderLink>
			<HeaderLink href="/blog">文章</HeaderLink>
			<HeaderLink href="/tags">标签</HeaderLink>
			<HeaderLink href="/about">关于</HeaderLink>
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: clamp(0.9rem, 2.5vw, 1.25rem) 1rem 0;
		background: white;
		box-shadow: 0 2px 8px rgba(var(--black), 5%);
	}
	h2 {
		margin: 0;
		font-size: clamp(1.35rem, calc(1.15rem + 0.8vw), 1.65rem);
	}
	.site-title {
		width: 100%;
		text-align: center;
	}

	h2 a,
	h2 a.active {
		text-decoration: none;
	}
	.site-title a,
	.site-title a.active {
		display: flex;
		width: 100%;
		align-items: center;
		justify-content: center;
		padding: 0;
		border-bottom: 0;
		color: #7bbcff;
	}
	nav {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
	}
	.internal-links {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
	}
	nav a {
		padding: clamp(0.75rem, 2vw, 1rem) clamp(0.4rem, 1.5vw, 0.5rem);
		color: var(--black);
		border-bottom: 4px solid transparent;
		font-size: clamp(0.95rem, calc(0.9rem + 0.2vw), 1rem);
		text-decoration: none;
	}
	nav a.active {
		text-decoration: none;
		border-bottom-color: white;
	}
	@media (max-width: 480px) {
		.internal-links {
			width: 100%;
			justify-content: space-around;
		}
		nav a {
			padding-right: 0.25rem;
			padding-left: 0.25rem;
		}
	}
</style>
