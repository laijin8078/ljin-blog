---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';

const titleCharacters = Array.from(SITE_TITLE);
---

<header>
	<nav>
		<h2 class="site-title">
			<a href="/" aria-label={SITE_TITLE}>
				{titleCharacters.map((character) => <span aria-hidden="true">{character}</span>)}
			</a>
		</h2>
		<div class="internal-links">
			<HeaderLink href="/">首页</HeaderLink>
			<HeaderLink href="/blog">文章</HeaderLink>
			<HeaderLink href="/about">关于</HeaderLink>
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 1.25em 1em 0;
		background: white;
		box-shadow: 0 2px 8px rgba(var(--black), 5%);
	}
	h2 {
		margin: 0;
		font-size: 1.35em;
	}
	.site-title {
		width: 100%;
	}

	h2 a,
	h2 a.active {
		text-decoration: none;
	}
	.site-title a,
	.site-title a.active {
		display: flex;
		width: 100%;
		align-items: center;
		justify-content: space-between;
		padding: 0;
		border-bottom: 0;
		color: var(--accent);
	}
	nav {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
	}
	.internal-links {
		display: flex;
		justify-content: center;
	}
	nav a {
		padding: 1em 0.5em;
		color: var(--black);
		border-bottom: 4px solid transparent;
		text-decoration: none;
	}
	nav a.active {
		text-decoration: none;
		border-bottom-color: white;
	}
</style>
