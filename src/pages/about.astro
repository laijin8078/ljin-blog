---
import { Image } from 'astro:assets';
import AboutImage from '../assets/云南的月.jpg';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title="关于" description="关于来进" />
	</head>
	<body>
		<Header />
		<main class="about-page">
			<Image src={AboutImage} alt="云南的月" class="about-image" />
		</main>
		<Footer />
	</body>
</html>

<style>
	.about-page {
		width: min(860px, calc(100% - 2em));
		margin: auto;
		padding: 2em 1em 4em;
	}

	.about-image {
		display: block;
		width: 100%;
		height: auto;
		border-radius: 8px;
		box-shadow: var(--box-shadow);
	}
</style>
