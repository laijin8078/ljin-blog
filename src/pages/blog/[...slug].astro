---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';
import { getFrontmatterDatePrecision } from '../../utils/frontmatterDates';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	return posts.map((post) => ({
		params: { slug: post.id },
		props: post,
	}));
}
type Props = CollectionEntry<'blog'>;

const post = Astro.props;
const { Content } = await render(post);
const pubDatePrecision = getFrontmatterDatePrecision(post.filePath, 'pubDate');
const updatedDatePrecision = getFrontmatterDatePrecision(post.filePath, 'updatedDate');
---

<BlogPost
	{...post.data}
	slug={post.id}
	pubDatePrecision={pubDatePrecision}
	updatedDatePrecision={updatedDatePrecision}
>
	<Content />
</BlogPost>
